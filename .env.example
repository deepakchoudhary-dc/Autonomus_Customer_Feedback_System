APP_NAME=Autonomous Customer Feedback System
LOG_LEVEL=INFO
OPENAI_API_KEY=replace-with-openai-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_MULTIMODAL_MODEL=gpt-4o-mini
OPENAI_RESOLUTION_MODEL=gpt-4o
OPENAI_EVALUATOR_MODEL=gpt-4o-mini
PINECONE_API_KEY=replace-with-pinecone-key
PINECONE_INDEX_NAME=customer-feedback
PINECONE_NAMESPACE=feedback
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_FEEDBACK_EVENTS=feedback-events
KAFKA_TOPIC_FEEDBACK_MULTIMODAL_EVENTS=feedback-multimodal-events
KAFKA_TOPIC_CRITICAL_BUGS=critical-bugs-identified
KAFKA_TOPIC_JIRA_RESOLVED=jira-issues-resolved
KAFKA_TOPIC_CUSTOMER_NOTIFICATIONS=customer-resolution-notifications
KAFKA_TOPIC_CHURN_ALERTS=customer-churn-alerts
KAFKA_TOPIC_RLHF_FEEDBACK=rlhf-feedback-events
KAFKA_TOPIC_RLHF_MODEL_UPDATES=rlhf-model-updates
KAFKA_CONSUMER_GROUP_ANOMALY=anomaly-detector-worker
KAFKA_CONSUMER_GROUP_JIRA=jira-sync-worker
KAFKA_CONSUMER_GROUP_RESOLUTION_NOTIFIER=resolution-notifier-worker
KAFKA_CONSUMER_GROUP_CHURN_PREDICTOR=churn-predictor-worker
KAFKA_CONSUMER_GROUP_RLHF=rlhf-trainer-worker
ANOMALY_CLUSTER_THRESHOLD=3
CHURN_ALERT_THRESHOLD=0.7
CHURN_MODEL_PATH=artifacts/churn_model.json
RLHF_FEEDBACK_STORE_PATH=data/rlhf_feedback.jsonl
RLHF_REWARD_MODEL_PATH=artifacts/reward_model.json
RLHF_TRAINING_MIN_SAMPLES=20
RLHF_TRAINING_BATCH_SIZE=10
DATABASE_URL=postgresql+asyncpg://feedback:feedback@localhost:5432/feedback_db
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=replace-with-jira-email
JIRA_API_TOKEN=replace-with-jira-api-token
JIRA_PROJECT_KEY=FB
JIRA_ISSUE_TYPE_EPIC=Epic
INTERNAL_DASHBOARD_BASE_URL=https://internal.example.com/customers
